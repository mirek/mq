{
  "name": "@prelude/mq-workspace",
  "version": "0.0.0",
  "private": true,
  "description": "Query, validate, and transform Markdown as structured documents.",
  "type": "module",
  "packageManager": "pnpm@11.13.0",
  "repository": "github:mirek/mq",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=11.0.0"
  },
  "scripts": {
    "benchmark": "pnpm build && node benchmarks/resource-limits.mjs",
    "build": "pnpm --recursive --if-present run build",
    "check": "pnpm lint && pnpm typecheck && pnpm test && pnpm test:artifacts",
    "clean": "pnpm --recursive --if-present run clean",
    "lint": "oxlint --deny-warnings .",
    "test": "pnpm --recursive --if-present run test",
    "test:artifacts": "pnpm build && node --test test/*.test.mjs",
    "typecheck": "pnpm --recursive --if-present run typecheck"
  },
  "devDependencies": {
    "@prelude/mq": "workspace:*",
    "@prelude/mq-cli": "workspace:*",
    "@types/node": "catalog:",
    "oxlint": "catalog:",
    "typescript": "catalog:"
  }
}
