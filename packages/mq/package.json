{
  "name": "@prelude/mq",
  "version": "0.0.0",
  "description": "A lossless Markdown query, validation, and transformation engine.",
  "type": "module",
  "sideEffects": false,
  "files": ["dist"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mirek/mq.git",
    "directory": "packages/mq"
  },
  "scripts": {
    "build": "tsc --build tsconfig.build.json",
    "clean": "rm -rf dist *.tsbuildinfo",
    "test": "node --test",
    "typecheck": "tsc --build"
  },
  "dependencies": {
    "@prelude/parser": "catalog:",
    "mdast-util-from-markdown": "2.0.3",
    "mdast-util-frontmatter": "2.0.1",
    "mdast-util-gfm": "3.1.0",
    "micromark-extension-frontmatter": "2.0.0",
    "micromark-extension-gfm": "3.0.0",
    "re2js": "2.8.6"
  },
  "devDependencies": {
    "@types/mdast": "4.0.4"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
