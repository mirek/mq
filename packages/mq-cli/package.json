{
  "name": "@prelude/mq-cli",
  "version": "0.0.0",
  "description": "Command-line interface for @prelude/mq.",
  "type": "module",
  "exports": {},
  "files": ["bin", "dist", "src"],
  "bin": {
    "mq": "./bin/mq.js"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mirek/mq.git",
    "directory": "packages/mq-cli"
  },
  "scripts": {
    "build": "tsc --build tsconfig.build.json",
    "clean": "rm -rf dist *.tsbuildinfo",
    "test": "pnpm run build && node --test --test-concurrency=1",
    "typecheck": "pnpm --filter @prelude/mq build && tsc --build"
  },
  "dependencies": {
    "@prelude/mq": "workspace:*"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
